{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dreamshop-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-23",
  "workers_dev": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "r2_buckets": [
    {
      "binding": "PRODUCT_MEDIA",
      "bucket_name": "dream-shop"
    }
  ]
}
