generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryMethod {
  POST_OFFICE
  ADDRESS
  SCHEDULE
  TAXI
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  CARD_ONLINE
  CARD_ON_DELIVERY
  BANK_TRANSFER
}

enum TelegramChallengeStatus {
  PENDING_CONTACT
  READY_FOR_PASSWORD
  CONSUMED
  EXPIRED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_STATUS_CHANGED
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  emailVerified       Boolean  @default(false)
  image               String?
  phoneNumber         String?  @unique
  phoneNumberVerified Boolean  @default(false)
  role                UserRole @default(CUSTOMER)
  telegramUserId      String?  @unique
  telegramUsername    String?
  firebaseUid         String?  @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  orders   Order[]

  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}

model TelegramAuthChallenge {
  id             String                  @id @default(cuid())
  tokenHash      String                  @unique
  telegramUserId String?
  telegramChatId String?
  telegramName   String?
  phoneNumber    String?
  status         TelegramChallengeStatus @default(PENDING_CONTACT)
  attempts       Int                     @default(0)
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([telegramUserId, status])
  @@index([status, expiresAt])
  @@map("telegram_auth_challenges")
}

model TelegramUpdate {
  updateId   String   @id
  receivedAt DateTime @default(now())

  @@index([receivedAt])
  @@map("telegram_updates")
}

model Category {
  id               String     @id @default(cuid())
  legacyFirebaseId String?    @unique
  name             String
  slug             String     @unique
  description      String?
  imageUrl         String?
  isActive         Boolean    @default(true)
  sortOrder        Int        @default(0)
  parentId         String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  parent           Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children         Category[] @relation("CategoryTree")
  products         Product[]

  @@index([parentId])
  @@index([isActive, sortOrder])
  @@map("categories")
}

model Product {
  id               String         @id @default(cuid())
  legacyFirebaseId String?        @unique
  sku              String?        @unique
  name             String
  slug             String         @unique
  description      String?
  price            Decimal        @db.Decimal(12, 2)
  originalPrice    Decimal?       @db.Decimal(12, 2)
  currency         String         @default("UAH") @db.Char(3)
  inStock          Boolean        @default(true)
  stockQuantity    Int?
  weight           String?
  ingredients      String?
  organic          Boolean        @default(false)
  isActive         Boolean        @default(true)
  metadata         Json?
  categoryId       String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  category         Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  orderItems       OrderItem[]

  @@index([categoryId, isActive])
  @@index([isActive, createdAt])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  publicId  String?
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, position])
  @@index([productId])
  @@map("product_images")
}

model Order {
  id                        String               @id @default(cuid())
  number                    Int                  @unique @default(autoincrement())
  legacyFirebaseId          String?              @unique
  userId                    String?
  status                    OrderStatus          @default(PENDING)
  total                     Decimal              @db.Decimal(12, 2)
  currency                  String               @default("UAH") @db.Char(3)
  customerFirstName         String
  customerLastName          String
  customerPhone             String
  deliveryCity              String
  deliveryMethod            DeliveryMethod
  deliveryDetails           String
  establishmentName         String?
  isPrivatePerson           Boolean              @default(true)
  paymentMethod             PaymentMethod
  contactForClarification   Boolean              @default(false)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  user                      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  items                     OrderItem[]
  notificationOutboxEntries NotificationOutbox[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String?
  productName     String
  productSku      String?
  unitPrice       Decimal  @db.Decimal(12, 2)
  quantity        Int
  lineTotal       Decimal  @db.Decimal(12, 2)
  imageUrl        String?
  productSnapshot Json?
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model NotificationOutbox {
  id               String             @id @default(cuid())
  deduplicationKey String             @unique
  orderId          String?
  type             NotificationType
  status           NotificationStatus @default(PENDING)
  payload          Json
  attempts         Int                @default(0)
  availableAt      DateTime           @default(now())
  lockedAt         DateTime?
  lastError        String?
  sentAt           DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  order            Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([status, availableAt])
  @@index([orderId])
  @@map("notification_outbox")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
