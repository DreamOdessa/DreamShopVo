{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/nova-poshta",
      "dest": "/api/nova-poshta.ts"
    },
    {
      "src": "/",
      "dest": "/index.html",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow, noarchive",
        "Cache-Control": "no-store, max-age=0"
      }
    },
    {
      "src": "/index.html",
      "dest": "/index.html",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow, noarchive",
        "Cache-Control": "no-store, max-age=0"
      }
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow, noarchive",
        "Cache-Control": "no-store, max-age=0"
      }
    }
  ]
}
